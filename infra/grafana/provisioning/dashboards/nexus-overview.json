{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"order-service|inventory-service|payment-service|notification-service|api-gateway\"}[5m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\",application=~\"order-service|inventory-service|payment-service|api-gateway\"}[5m])) by (application, status)",
          "legendFormat": "{{application}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "p95 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"order-service|inventory-service|api-gateway\"}[5m])) by (le, application))",
          "legendFormat": "{{application}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Order Saga Outcomes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{uri=\"/api/v1/orders\",method=\"POST\",application=\"order-service\"}) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"notification-service\"}",
          "legendFormat": "threads"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}] } },
        "overrides": []
      }
    },
    {
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",application=~\"order-service|payment-service|inventory-service|notification-service|api-gateway\"} / 1024 / 1024",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Kafka Consumer Lag (estimated)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{application=~\"order-service|payment-service|inventory-service|notification-service\"}) by (application, topic)",
          "legendFormat": "{{application}} / {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Database Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=~\"order-service|payment-service|inventory-service\"}",
          "legendFormat": "{{application}} active"
        },
        {
          "expr": "hikaricp_connections_idle{application=~\"order-service|payment-service|inventory-service\"}",
          "legendFormat": "{{application}} idle"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Redis Operations Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(spring_data_redis_duration_seconds_count{application=\"inventory-service\"}[5m])) by (command)",
          "legendFormat": "{{command}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["nexus", "microservices"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Nexus — Platform Overview",
  "uid": "nexus-overview"
}
